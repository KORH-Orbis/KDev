generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int           @id @default(autoincrement())
  name         String
  email        String        @unique
  password     String
  role         UserRole      @default(TECHNICIAN)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  repairOrders RepairOrder[]
  auditLogs    AuditLog[]
}

model Client {
  id           String        @id @default(cuid())
  name         String
  email        String?
  phone        String?
  password     String?
  trackingId   String?       @unique
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  repairOrders RepairOrder[]
  devices      Device[]
}

model RepairOrder {
  id            String      @id @default(cuid())
  trackingCode  String      @unique
  clientId      String
  deviceType    DeviceType
  deviceBrand   String?
  deviceModel   String?
  deviceSerial  String?
  issue         String
  status        OrderStatus @default(RECEIVED)
  budgetAmount  Decimal?    @db.Decimal(12, 2)
  budgetStatus  String?
  technicianId  Int?
  guaranteeDays Int         @default(10)
  notes         String?
  completedAt   DateTime?
  deliveredAt   DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  client        Client      @relation(fields: [clientId], references: [id])
  technician    User?       @relation(fields: [technicianId], references: [id])
  payments      Payment[]
  photos        Photo[]
  deviceId      String?
  device        Device?       @relation(fields: [deviceId], references: [id])
  orderParts    OrderPart[]

  @@index([clientId])
  @@index([technicianId])
  @@index([status])
}

model Payment {
  id            String        @id @default(cuid())
  repairOrderId String
  amount        Decimal       @db.Decimal(12, 2)
  method        PaymentMethod
  reference     String?
  notes         String?
  createdAt     DateTime      @default(now())
  repairOrder   RepairOrder   @relation(fields: [repairOrderId], references: [id])

  @@index([repairOrderId])
}

model Photo {
  id            String      @id @default(cuid())
  repairOrderId String
  url           String
  caption       String?
  createdAt     DateTime    @default(now())
  repairOrder   RepairOrder @relation(fields: [repairOrderId], references: [id])

  @@index([repairOrderId])
}

model Device {
  id            String        @id @default(cuid())
  clientId      String
  type          DeviceType
  brand         String?
  model         String?
  serialNumber  String?
  imei          String?
  color         String?
  accessories   String?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  client        Client        @relation(fields: [clientId], references: [id])
  repairOrders  RepairOrder[]

  @@index([clientId])
  @@index([serialNumber])
  @@index([imei])
}

model SparePart {
  id           String      @id @default(cuid())
  name         String
  category     String?
  brand        String?
  model        String?
  costPrice    Decimal     @db.Decimal(12, 2)
  sellingPrice Decimal?    @db.Decimal(12, 2)
  stock        Int         @default(0)
  minStock     Int         @default(1)
  supplier     String?
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  orderParts   OrderPart[]
}

model OrderPart {
  id            String      @id @default(cuid())
  repairOrderId String
  sparePartId   String
  quantity      Int         @default(1)
  unitPrice     Decimal     @db.Decimal(12, 2)
  createdAt     DateTime    @default(now())
  repairOrder   RepairOrder @relation(fields: [repairOrderId], references: [id])
  sparePart     SparePart   @relation(fields: [sparePartId], references: [id])

  @@index([repairOrderId])
  @@index([sparePartId])
}

model AppConfig {
  id              Int      @id @default(1)
  appName         String   @default("LKDev")
  appDescription  String   @default("Reparación de computadoras, portátiles, teléfonos y desarrollo web")
  contactEmail    String   @default("contacto@lkdev.app")
  phone           String   @default("")
  whatsapp        String   @default("")
  address         String   @default("")
  guaranteeDays   Int      @default(10)
  trackingPrefix  String   @default("LK")
  sparePartMargin Decimal  @db.Decimal(3, 2) @default(1.5)
  updatedAt       DateTime @updatedAt
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  action    String
  entity    String
  entityId  String?
  details   String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity])
  @@index([createdAt])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  service   String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

enum UserRole {
  ADMIN
  TECHNICIAN
}

enum OrderStatus {
  RECEIVED
  DIAGNOSING
  BUDGETED
  APPROVED
  REPAIRING
  REPAIRED
  DELIVERED
  REJECTED
}

enum DeviceType {
  PC
  LAPTOP
  PHONE
  TABLET
  OTHER
}

enum PaymentMethod {
  CASH
  TRANSFER
  CARD
  OTHER
}
